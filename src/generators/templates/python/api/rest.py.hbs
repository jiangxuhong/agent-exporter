"""
REST API Endpoints

Auto-generated from OpenClaw agent workspace
"""

from fastapi import APIRouter, HTTPException, Depends
from typing import Optional, Dict, Any
from pydantic import BaseModel, Field
import structlog

from agent.config import load_agent_config
from agent.prompts import PromptTemplates, SYSTEM_PROMPT
from agent.memory import AgentMemory
from llm.providers import LLMProviderManager

logger = structlog.get_logger()
router = APIRouter()


# Request/Response models
class ChatRequest(BaseModel):
    """Chat request model."""
    message: str = Field(..., description="User message", min_length=1)
    session_id: Optional[str] = Field(None, description="Session identifier")
    context: Optional[Dict[str, Any]] = Field(None, description="Additional context")


class ChatResponse(BaseModel):
    """Chat response model."""
    response: str = Field(..., description="Agent response")
    session_id: str = Field(..., description="Session identifier")
    metadata: Dict[str, Any] = Field(default_factory=dict, description="Response metadata")


class SessionInfo(BaseModel):
    """Session information model."""
    session_id: str
    message_count: int
    created_at: str
    last_active: str


# Session storage (in production, use Redis or database)
sessions: Dict[str, Dict[str, Any]] = {}


def get_memory() -> AgentMemory:
    """Dependency: Get memory manager."""
    return AgentMemory()


def get_llm_manager() -> LLMProviderManager:
    """Dependency: Get LLM provider manager."""
    from llm.config import load_llm_config
    config = load_llm_config()
    return LLMProviderManager(config)


@router.post("/chat", response_model=ChatResponse)
async def chat(
    request: ChatRequest,
    memory: AgentMemory = Depends(get_memory),
    llm_manager: LLMProviderManager = Depends(get_llm_manager)
) -> ChatResponse:
    """Process a chat message.

    Args:
        request: Chat request with message and optional session ID
        memory: Memory manager dependency
        llm_manager: LLM provider manager dependency

    Returns:
        Chat response with agent reply

    Raises:
        HTTPException: If processing fails
    """
    try:
        # Get or create session
        session_id = request.session_id or f"session-{hash(request.message) % 1000000}"

        if session_id not in sessions:
            sessions[session_id] = {
                "messages": [],
                "created_at": datetime.now().isoformat(),
                "last_active": datetime.now().isoformat()
            }

        session = sessions[session_id]
        session["last_active"] = datetime.now().isoformat()

        # Build chat history
        chat_history = "\n".join([
            f"Human: {msg['human']}\nAssistant: {msg['assistant']}"
            for msg in session["messages"][-10:]  # Last 10 exchanges
        ])

        # Get memory context
        memory_context = memory.get_context_window(max_chars=4000)

        # Get LLM provider
        llm = llm_manager.get_provider()

        # Format prompt
        prompt = PromptTemplates.format_chat_prompt(
            system_prompt=SYSTEM_PROMPT,
            chat_history=chat_history,
            input=request.message,
            long_term_memory=memory_context if memory_context else ""
        )

        # Call LLM
        logger.info("Processing chat message",
                   session_id=session_id,
                   message_len=len(request.message))

        response = await llm.ainvoke(prompt)
        response_text = response.content if hasattr(response, 'content') else str(response)

        # Update session
        session["messages"].append({
            "human": request.message,
            "assistant": response_text,
            "timestamp": datetime.now().isoformat()
        })

        logger.info("Chat processed successfully",
                   session_id=session_id,
                   response_len=len(response_text))

        return ChatResponse(
            response=response_text,
            session_id=session_id,
            metadata={
                "model": llm.model_name if hasattr(llm, 'model_name') else "unknown",
                "tokens_used": getattr(response, 'usage', {}).get('total_tokens', 0),
                "message_count": len(session["messages"])
            }
        )

    except Exception as e:
        logger.error("Chat processing failed", error=str(e))
        raise HTTPException(status_code=500, detail=f"Chat processing failed: {str(e)}")


@router.get("/sessions/{session_id}", response_model=SessionInfo)
async def get_session(session_id: str) -> SessionInfo:
    """Get session information.

    Args:
        session_id: Session identifier

    Returns:
        Session information

    Raises:
        HTTPException: If session not found
    """
    if session_id not in sessions:
        raise HTTPException(status_code=404, detail="Session not found")

    session = sessions[session_id]

    return SessionInfo(
        session_id=session_id,
        message_count=len(session["messages"]),
        created_at=session["created_at"],
        last_active=session["last_active"]
    )


@router.delete("/sessions/{session_id}")
async def delete_session(session_id: str) -> Dict[str, str]:
    """Delete a session.

    Args:
        session_id: Session identifier

    Returns:
        Success message

    Raises:
        HTTPException: If session not found
    """
    if session_id not in sessions:
        raise HTTPException(status_code=404, detail="Session not found")

    del sessions[session_id]
    logger.info("Session deleted", session_id=session_id)

    return {"status": "deleted", "session_id": session_id}


@router.get("/sessions")
async def list_sessions() -> Dict[str, Any]:
    """List all active sessions.

    Returns:
        List of session summaries
    """
    return {
        "sessions": [
            {
                "session_id": sid,
                "message_count": len(session["messages"]),
                "last_active": session["last_active"]
            }
            for sid, session in sessions.items()
        ],
        "total": len(sessions)
    }


